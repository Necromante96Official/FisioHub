{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "rootDir": "ts",
    "outDir": "js",
    "strict": true,
    "noEmitOnError": true,
    "skipLibCheck": true,
    "declaration": false,
    "sourceMap": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["ts/**/*.ts"],
  "exclude": ["js", "_oldversion", "node_modules"]
}