{
  "manifest_version": 3,
  "name": "zenfisio-ColetorDeDados",
  "version": "0.5.5",
  "description": "Coleta automatica de dados de agendamentos do Zenfisio",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://app.zenfisio.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.zenfisio.com/*"],
      "js": ["collector.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-small.png",
    "48": "icons/icon-medium.png",
    "128": "icons/icon-large.png"
  },
  "commands": {
    "toggle-collector": {
      "suggested_key": {
        "default": "Ctrl+Shift+X",
        "mac": "Command+Shift+X"
      },
      "description": "Ativar ou desativar o coletor de dados"
    }
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "zenfisio-ColetorDeDados",
    "default_icon": {
      "16": "icons/icon-small.png",
      "48": "icons/icon-medium.png"
    }
  }
}
