{
  "manifest_version": 3,
  "name": "Zenfisio Collector",
  "version": "0.4.3",
  "description": "Coleta automatica de dados de agendamentos do Zenfisio",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://app.zenfisio.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.zenfisio.com/*"],
      "js": ["collector.js"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Zenfisio Collector",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
